# --- LLM (set one; Gemini wins if both are set) ---
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-2.5-flash
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-5

# --- Airtable ---
AIRTABLE_API_KEY=pat...
AIRTABLE_BASE_ID=app...

# --- Support inbox (IMAP; for Gmail create an App Password) ---
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
# Watch a dedicated label/folder instead of the whole inbox (recommended)
IMAP_MAILBOX=INBOX
# Only process mail received after this ISO date; empty = from service start; "all" = entire backlog
IMAP_SINCE=
IMAP_USER=support@yourcompany.com
IMAP_PASSWORD=app-password-here

# --- Outgoing mail (SMTP, for acknowledgments) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=support@yourcompany.com
SMTP_PASSWORD=app-password-here
SMTP_FROM="Acme SaaS Support <support@yourcompany.com>"

# --- Slack (bonus notifications; leave empty to disable) ---
SLACK_WEBHOOK_URL=
